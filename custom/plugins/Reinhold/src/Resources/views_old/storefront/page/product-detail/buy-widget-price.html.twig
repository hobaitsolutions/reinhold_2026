 {% block page_product_detail_price_unit_reference_content %}
     {# @deprecated tag:v6.4.0 #}
     {% block page_product_detail_price_unit_refrence_content %}
         <span class="price-unit-reference-content">
             {% set unit =  price.referencePrice.unitName %}
             {% if (unit == '1 l') %}
                 {% set unit =  '1 Liter' %}
             {% endif %}
             {% if (unit == 'l') %}
                 {% set unit =  'Liter' %}
             {% endif %}
            ({{ price.referencePrice.price|currency }}{{ "general.star"|trans|sw_sanitize }} / {% if referncePrice.referenceUnit != 1 %}{{ referncePrice.referenceUnit }}{% endif %} {{ unit }})
        </span>
     {% endblock %}
 {% endblock %}
{% block page_product_detail_price_content %}

    {{ parent() }}
    {% set packUnit = page.product.packUnit %}
    {% if packUnit is empty %}
        {% set packUnit = page.product.unit.translated.name %}
    {% endif %}
    {% if packUnit is not empty %}
        <span class="packunit">
            &nbsp;|&nbsp; {% if page.product.customFields.custom_product_pack_unit_quantity is not empty %}{{ page.product.customFields.custom_product_pack_unit_quantity }} {% else %} 1 {% endif %}{{ packUnit }}
        </span>
    {% endif %}
    {% if page.product.calculatedPrices|length >= 1 %}
        {% set stdprice = page.product.price|first.net %}
        {% set savings = (( 1-(page.product.calculatedPrices.elements|first.unitprice/stdprice))*100)|round %}

        <span class="std-price">(Standardpreis: {{ (stdprice|currency) }})</span>
        {% if savings > 1 %}
            <div class="your-savings">
                <strong>Sie sparen: {{ savings }}%</strong>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}

