{% sw_extends '@Reinhold/storefront/base.html.twig' %}
{#Verkaufstagebuch#}
{% block base_content %}
    <style>
        .quickorder-table th a {
            color: #0055aa;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
        }
        .quickorder-table th a:hover {
            text-decoration: underline;
            color: #003366;
        }
        .quickorder-table th .sort-indicator {
            margin-left: 5px;
            font-size: 0.8em;
        }
    </style>
    <div class="quickorder-table">
        <h2>{{ "custom.goodsellingdaybook"|trans }}</h2>

        <div class="chose-columns">
            <label>
                <input name="data-toggle" type="checkbox" value="0" checked/>
                {{ "account.orderNumber"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="1" checked/>
                {{ "account.orderItemColumnDate"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="2" checked/>
                {{ "detail.unit"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="3" checked/>
                {{ "detail.unitName"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="4" checked/>
                {{ "detail.ordernumberLabel"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="5" checked/>
                {{ "custom.product"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="6" checked/>
                {{ "account.orderItemColumnPrice"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="7"/>
                {{ "account.discount"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="8" checked/>
                {{ "account.danger"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="9"/>
                {{ "custom.hSentences"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="10"/>
                {{ "custom.pSentences"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="11"/>
                {{ "custom.adrNumbers"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="12"/>
                {{ "custom.adrSpecs"|trans }}
            </label>
            <label>
                <input name="data-toggle" type="checkbox" value="13"/>
                {{ "custom.adrText"|trans }}
            </label>

        </div>
        <div class="table-loading"></div>
        <div class="table-wrap" style="overflow-x: scroll; display: none">
            <table class="table table-striped table-bordered dt-responsive nowrap" id="orderhistory">
                <thead>
                <tr>
                    {% set nextOrder = (order == 'asc' ? 'desc' : 'asc') %}
                    <th data-priority="1" scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'orderNumber', 'order': (sort == 'orderNumber' ? nextOrder : 'asc'), 'p': p, 'limit': limit }) }}">
                            {{ "account.orderNumber"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'orderNumber' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th data-priority="2" scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'date', 'order': (sort == 'date' ? nextOrder : 'desc'), 'p': p, 'limit': limit }) }}">
                            {{ "account.orderItemColumnDate"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'date' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'count', 'order': (sort == 'count' ? nextOrder : 'asc'), 'p': p, 'limit': limit }) }}">
                            {{ "detail.unit"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'count' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th scope="col">{{ "detail.unitName"|trans }}</th>
                    <th data-priority="4" scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'productNumber', 'order': (sort == 'productNumber' ? nextOrder : 'asc'), 'p': p, 'limit': limit }) }}">
                            {{ "detail.ordernumberLabel"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'productNumber' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th style="max-width: 20%" data-priority="3" scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'name', 'order': (sort == 'name' ? nextOrder : 'asc'), 'p': p, 'limit': limit }) }}">
                            {{ "custom.product"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'name' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'price', 'order': (sort == 'price' ? nextOrder : 'asc'), 'p': p, 'limit': limit }) }}">
                            {{ "account.orderItemColumnPrice"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'price' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th scope="col">{{ "account.discount"|trans }}</th>
                    <th scope="col">{{ "account.danger"|trans }}</th>
                    <th scope="col">{{ "custom.hSentences"|trans }}</th>
                    <th scope="col">{{ "custom.pSentences"|trans }}</th>
                    <th scope="col">{{ "custom.adrNumbers"|trans }}</th>
                    <th scope="col">{{ "custom.adrSpecs"|trans }}</th>
                    <th scope="col">{{ "custom.adrText"|trans }}</th>
                </tr>
                </thead>
                <tbody>
                {% for order in allorders %}
                    {% for item in order.items %}
                        {% set currentProduct = products[item.id] %}
                        <tr>
                            <td>{{ order.orderNumber }}</td>
                            <td data-order="{{ order.date|format_datetime( pattern='yyyy-MM-dd') }}">{{ order.date|format_datetime(pattern='dd.MM.yyyy') }}</td>
                            <td>{{ item.count }}
                            </td>
                            <td>
                                {% if item.unit is not empty %}
                                    {{ item.unit }}
                                {% else %}
                                    Stück
                                {% endif %}
                            </td>
                            <td>{{ currentProduct.productNumber }}</td>
                            <td class="product-name">
                                {% if currentProduct.active %}
                                    <a href="{{ seoUrl('frontend.detail.page', {'productId': currentProduct.id}) }}"
                                       title="{{ currentProduct.name }}">{{ currentProduct.name }}</a>
                                {% else %}
                                    <span title="{{ item.name }}">{{  item.name }}</span> ¹
                                {% endif %}
                            </td>
                            <td>
                                <span class="text-right d-block">
                                {% if item.price is not empty %}
                                    {% set price =  item.price %}
                                {% else %}
                                    {% set price = currentProduct.price|first.net %}
                                {% endif %}
                                    {% if order.orderNumber ends with "GS"  %}
                                        {% set price = price * -1 %}
                                    {% endif %}
                                    {{price|number_format(2,',') }}
                                </span>
                            </td>
                            <td>
                                {% if item['discount1'] is not empty %}
                                    {{ item['discount1'] }}
                                {% else %}
                                    0 %
                                {% endif %}
                            </td>
                            <td>{{ currentProduct.hazards }}</td>
                            <td>{{ currentProduct.customFields.custom_product_HazardStatements|hazardDescription }}</td>
                            <td>{{ currentProduct.customFields.custom_product_hazards_p }}</td>
                            <td>{{ currentProduct.customFields.custom_product_AdrNumbers }}</td>
                            <td>{{ currentProduct.customFields.custom_product_AdrSpecs }}</td>
                            <td>{{ currentProduct.customFields.custom_product_AdrText }}</td>
                        </tr>
                    {% endfor %}
                {% endfor %}
                </tbody>
                <tfoot>
                <tr>
                    <th scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'orderNumber', 'order': (sort == 'orderNumber' ? nextOrder : 'asc'), 'p': p, 'limit': limit }) }}">
                            {{ "account.orderNumber"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'orderNumber' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'date', 'order': (sort == 'date' ? nextOrder : 'desc'), 'p': p, 'limit': limit }) }}">
                            {{ "account.orderItemColumnDate"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'date' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'count', 'order': (sort == 'count' ? nextOrder : 'asc'), 'p': p, 'limit': limit }) }}">
                            {{ "detail.unit"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'count' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th>{{ "detail.unitName"|trans }}</th>
                    <th scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'productNumber', 'order': (sort == 'productNumber' ? nextOrder : 'asc'), 'p': p, 'limit': limit }) }}">
                            {{ "detail.ordernumberLabel"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'productNumber' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th style="max-width: 20%" scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'name', 'order': (sort == 'name' ? nextOrder : 'asc'), 'p': p, 'limit': limit }) }}">
                            {{ "custom.product"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'name' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th scope="col">
                        <a href="{{ path('frontend.quickorder.table', { 'sort': 'price', 'order': (sort == 'price' ? nextOrder : 'asc'), 'p': p, 'limit': limit }) }}">
                            {{ "account.orderItemColumnPrice"|trans }}
                            <span class="sort-indicator">
                                {% if sort == 'price' %}
                                    {{ order == 'asc' ? '↑' : '↓' }}
                                {% else %}
                                    ↕
                                {% endif %}
                            </span>
                        </a>
                    </th>
                    <th>{{ "account.discount"|trans }}</th>
                    <th>{{ "account.danger"|trans }}</th>
                    <th scope="col">{{ "custom.hSentences"|trans }}</th>
                    <th scope="col">{{ "custom.pSentences"|trans }}</th>
                    <th scope="col">{{ "custom.adrNumbers"|trans }}</th>
                    <th scope="col">{{ "custom.adrSpecs"|trans }}</th>
                    <th scope="col">{{ "custom.adrText"|trans }}</th>
                </tr>
                </tfoot>
            </table>
        </div>

        <div class="text-center text-muted mb-4">
            {% set from = (p - 1) * limit + 1 %}
            {% set to = min(p * limit, total) %}
            {% if total > 0 %}
                {{ "custom.showingProducts"|trans({'%from%': from, '%to%': to, '%total%': total})|replace({'custom.showingProducts': 'Zeige ' ~ from ~ ' bis ' ~ to ~ ' von ' ~ total ~ ' Produkten'})|replace({'%from%': from, '%to%': to, '%total%': total}) }}
            {% else %}
                Zeige 0 bis 0 von 0 Produkten
            {% endif %}
        </div>

        {% if total > limit %}
            <div class="pagination-nav mt-4 mb-4">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center">
                        {% set totalPages = (total / limit)|round(0, 'ceil') %}

                        {# Previous Button #}
                        <li class="page-item {% if p <= 1 %}disabled{% endif %}">
                            <a class="page-link" href="{{ path('frontend.quickorder.table', { 'p': p - 1, 'limit': limit, 'sort': sort, 'order': order }) }}" aria-label="Previous">
                                <span class="text-white" aria-hidden="true">&laquo;</span>
                            </a>
                        </li>

                        {# Simple page numbers (limited to current, 2 before, 2 after) #}
                        {% for i in max(1, p - 2)..min(totalPages, p + 2) %}
                            <li class="page-item {% if i == p %}active{% endif %} ">
                                <a class="page-link block text-white" href="{{ path('frontend.quickorder.table', { 'p': i, 'limit': limit, 'sort': sort, 'order': order }) }}">{{ i }}</a>
                            </li>
                        {% endfor %}

                        {# Next Button #}
                        <li class="page-item {% if p >= totalPages %}disabled{% endif %}">
                            <a class="page-link" href="{{ path('frontend.quickorder.table', { 'p': p + 1, 'limit': limit, 'sort': sort, 'order': order }) }}" aria-label="Next">
                                <span class="text-white" aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        {% endif %}
        <div class="notice"><p>¹ {{ "custom.cantbeorderedonline"|trans }}</p></div>
    </div>
{% endblock %}
