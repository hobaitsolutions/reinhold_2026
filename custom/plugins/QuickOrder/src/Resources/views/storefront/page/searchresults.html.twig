{% sw_extends '@Reinhold/storefront/base.html.twig' %}
{% set listingColumns = 'col-sm-6 col-lg-4 col-xl-3' %}

{# Custom Search #}
{% block base_content %}
    <style>
        .bc-wrapper{
            display: none !important;
        }
    </style>

    <div class="filter-container mb-3 flex text-white" style="justify-content: space-between">
        <div class="serachresults">
            {{ total }} Resultate gefunden.
        </div>
        <div class="form-check">
            <input type="checkbox" class="form-check-input" id="toggle-available">
            <label class="form-check-label" for="toggle-available" id="toggle-available-label">Alle Produkte</label>
        </div>
    </div>
    <div class="row cms-listing-row js-listing-wrapper"
         data-aria-live-text="{{ ariaLiveText }}"{% if total > 0 %} role="list"{% endif %}>
        {% for product in products %}
            <div class="cms-listing-col {{ listingColumns }} mb-4" role="listitem">
                {% block element_product_listing_box %}
                    {% sw_include '@Storefront/storefront/component/product/card/box.html.twig' with {
                        layout: 'standard',
                        displayMode: ''
                    } %}
                {% endblock %}
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% set totalPages = (total / limit)|round(0, 'ceil') %}
    {% if totalPages > 1 %}
        <nav aria-label="Suchergebnis Paginierung" class="mt-3">
            <ul class="pagination">
                {% set prevPage = p - 1 %}
                <li class="page-item {% if p <= 1 %}disabled{% endif %}">
                    <a class="page-link text-white" href="{{ path('frontend.quickorder.search', {'query': query, 'p': prevPage, 'limit': limit}) }}" tabindex="-1">&laquo;</a>
                </li>

                {% set range = 2 %}
                {% if totalPages > 1 %}
                    <li class="page-item {% if p == 1 %}active{% endif %}">
                        <a class="page-link text-white" href="{{ path('frontend.quickorder.search', {'query': query, 'p': 1, 'limit': limit}) }}">1</a>
                    </li>

                    {% if p > range + 2 %}
                        <li class="page-item disabled"><span class="page-link text-white">...</span></li>
                    {% endif %}

                    {% set start = max(2, p - range) %}
                    {% set end = min(totalPages - 1, p + range) %}
                    {% if start <= end %}
                        {% for i in start..end %}
                            <li class="page-item {% if i == p %}active{% endif %}">
                                <a class="page-link text-white" href="{{ path('frontend.quickorder.search', {'query': query, 'p': i, 'limit': limit}) }}">{{ i }}</a>
                            </li>
                        {% endfor %}
                    {% endif %}

                    {% if p < totalPages - range - 1 %}
                        <li class="page-item disabled"><span class="page-link text-white">...</span></li>
                    {% endif %}

                    <li class="page-item {% if p == totalPages %}active{% endif %}">
                        <a class="page-link text-white" href="{{ path('frontend.quickorder.search', {'query': query, 'p': totalPages, 'limit': limit}) }}">{{ totalPages }}</a>
                    </li>
                {% endif %}

                {% set nextPage = p + 1 %}
                <li class="page-item {% if p >= totalPages %}disabled{% endif %}">
                    <a class="page-link text-white" href="{{ path('frontend.quickorder.search', {'query': query, 'p': nextPage, 'limit': limit}) }}">&raquo;</a>
                </li>
            </ul>
        </nav>
    {% endif %}
    <table class="text-white">
        <thead>
        <tr>
            <th>pnr</th>
            <th>id</th>
            <th>name</th>
            <th>weight</th>
        </tr>
        </thead>
        {% for row in queryResults %}
            <tr>
                {% for col in row %}
                    <td style="border:1px #ccc solid; padding: .333rem">{{ col }}</td>
                {% endfor %}
            </tr>
        {% endfor %}
    </table>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let showOnlyAvailable = false;
            let totalProductCount = 0;
            let availableProductCount = 0;
            const toggleAvailableCheckbox = document.getElementById('toggle-available');
            const toggleAvailableLabel = document.getElementById('toggle-available-label');
            const searchResultsCount = document.querySelector('.serachresults');


            // Function to filter products based on availability
            function filterProducts() {
                const productCards = document.querySelectorAll('.product-box');

                totalProductCount = productCards.length;
                availableProductCount = 0;
                let visibleProductCount = 0;

                productCards.forEach(card => {
                    if (card.getAttribute('data-available') === 'true') {
                        availableProductCount++;
                    }

                    if (showOnlyAvailable && card.getAttribute('data-available') !== 'true') {
                        card.closest('.cms-listing-col').style.display = 'none';
                    } else {
                        card.closest('.cms-listing-col').style.display = '';
                        visibleProductCount++;
                    }
                });

                // Update label text with counts
                toggleAvailableLabel.textContent = showOnlyAvailable
                    ? `Nur verfügbare Produkte anzeigen (${availableProductCount})`
                    : `Nur verfügbare Produkte anzeigen (${availableProductCount} / ${totalProductCount})`;

                // Update search results count (client-side filtered count)
                searchResultsCount.textContent = `${visibleProductCount} von {{ total }} Resultaten angezeigt.`;
            }

            // Add event listener for toggle checkbox
            toggleAvailableCheckbox.addEventListener('change', function () {
                showOnlyAvailable = this.checked;
                filterProducts();
            });

            // Initialize product counts and label
            filterProducts();
        });
    </script>

{% endblock %}
